[user]
	name = Christoph Sawade
	email = christoph@sawade.me

# Use work email for repos under github.com/fitanalytics
[includeIf "gitdir:~/src/github.com/fitanalytics/"]
	path = ~/.gitconfig-work
[includeIf "hasconfig:remote.*.url:git@github.com:fitanalytics/**"]
	path = ~/.gitconfig-work

[core]
	quotepath = false
	excludesfile = ~/.gitignore
	pager = delta

[init]
	defaultBranch = main

[push]
	default = current

[pull]
	rebase = true

[branch]
	autosetuprebase = always

[fetch]
	prune = true

[rebase]
	autoStash = true

[merge]
	conflictStyle = zdiff3

[rerere]
	enabled = true

[diff]
	rename = copies
	algorithm = histogram
	color = auto

[apply]
	whitespace = strip

[color]
	diff = auto
	status = auto
	branch = auto

[pager]
	color = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = true
	line-numbers = true

[alias]
	co = checkout
	ci = commit
	lola = log --graph --decorate --pretty=oneline --abbrev-commit --all

[url "git@github.com:"]
	insteadOf = https://github.com/
[diff "jupyternotebook"]
	command = git-nbdiffdriver diff
[merge "jupyternotebook"]
	driver = git-nbmergedriver merge %O %A %B %L %P
	name = jupyter notebook merge driver
[difftool "nbdime"]
	cmd = git-nbdifftool diff \"$LOCAL\" \"$REMOTE\" \"$BASE\"
[difftool]
	prompt = false
[mergetool "nbdime"]
	cmd = git-nbmergetool merge \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\"
[mergetool]
	prompt = false
