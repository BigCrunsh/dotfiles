#!/bin/bash
set -euo pipefail

usage() {
  cat <<EOF
Delete local branches that have been merged into the default branch.

Usage: $(basename "$0") [-n] [-h]

Options:
  -n    Dry run; print what would be deleted, don't delete.
  -h    Show this help.

Notes:
  - Deletes LOCAL branches only.
  - Skips the current branch, the default branch, and protected names
    (stable, develop, release-*).
  - Detects true merges, fast-forwards, and squash/rebase merges (where the
    branch's diff is already in the default branch under a new commit).
  - True merges are removed with 'git branch -d'. Squash/rebase merges are
    removed with 'git branch -D', since 'git branch -d' refuses them even
    though their changes are fully present in the default branch.
EOF
}

dry_run=0
while getopts 'nh' opt; do
  case "$opt" in
    n) dry_run=1 ;;
    h) usage; exit 0 ;;
    *) usage >&2; exit 1 ;;
  esac
done

# Detect default branch via origin/HEAD; fall back to main, then master.
default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null \
  | sed 's@^origin/@@' || true)
if [ -z "$default_branch" ]; then
  for candidate in main master; do
    if git show-ref --verify --quiet "refs/heads/$candidate"; then
      default_branch=$candidate
      break
    fi
  done
fi
if [ -z "$default_branch" ]; then
  echo "error: could not determine default branch" >&2
  exit 1
fi

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

git fetch --all --prune --quiet

protected="^($default_branch|stable|develop|release-.*)$"

# Branches checked out in any worktree (including the current one) cannot be
# deleted by git, so collect them up front and skip them.
worktree_branches=$(git worktree list --porcelain \
  | sed -n 's@^branch refs/heads/@@p')

# A branch counts as merged if its tip is an ancestor of the default branch
# (true merge / fast-forward) OR its combined diff already exists in the default
# branch (squash or rebase merge, which `git branch --merged` cannot detect).
is_merged() {
  local branch="$1"
  if git merge-base --is-ancestor "$branch" "$default_branch"; then
    return 0
  fi
  local mb tree synth
  mb=$(git merge-base "$default_branch" "$branch")
  tree=$(git rev-parse "$branch^{tree}")
  synth=$(git commit-tree "$tree" -p "$mb" -m _)
  [[ "$(git cherry "$default_branch" "$synth")" == "-"* ]]
}

candidates=()
while IFS= read -r branch; do
  candidates+=("$branch")
done < <(git branch --format='%(refname:short)' \
  | grep -Ev "$protected" \
  | grep -Fxv "$current_branch" \
  | grep -Fxvf <(printf '%s\n' "$worktree_branches") \
  | sed '/^$/d')

found=0
for branch in ${candidates[@]+"${candidates[@]}"}; do
  is_merged "$branch" || continue
  found=1
  if [ "$dry_run" -eq 1 ]; then
    echo "[dry-run] would delete: $branch"
  elif git merge-base --is-ancestor "$branch" "$default_branch"; then
    git branch -d "$branch"
  else
    git branch -D "$branch"
  fi
done

if [ "$found" -eq 0 ]; then
  echo "No merged branches to delete."
fi
